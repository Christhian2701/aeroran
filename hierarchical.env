# =============================================================================
# HIERARCHICAL RL ENVIRONMENT CONFIGURATION
# Configuração para execução do cenário scenario-hierarchical-xangai-UAV
# com o modelo SAC treinado
# =============================================================================

# --- Caminhos do Sistema ---
NS3_PATH=.
NSORAN_GYM_PATH=ns-o-ran-gym
SAC_MODEL_PATH=sac1/sac_hierarchical_model_best_model/best_model.zip
SCENARIO_NAME=scenario-hierarchical-xangai-UAV

# --- Diretório de Saída ---
OUTPUT_FOLDER=output_hierarchical_uav
CSV_METRICS_PATH=output_hierarchical_uav/qos_hierarchical_metrics_UAV.csv
DATABASE_PATH=output_hierarchical_uav/hierarchical_metrics.db

# --- Parâmetros da Simulação NS3 ---
SIM_TIME=5.0
NUM_UES=9
CONFIGURATION=1
TRAFFIC_MODEL=3
INDICATION_PERIODICITY=0.1
HO_SINR_DIFFERENCE=3
HANDOVER_MODE=DynamicTtt
POSITION_ALLOCATOR=2
USE_SEMAPHORES=1
RNG_RUN=400

# --- Parâmetros do Modelo SAC ---
DETERMINISTIC=true
VERBOSE=false
TS_REWARD_WEIGHT=1.0
DO_HEURISTIC=false

# --- Configuração de Execução ---
NUM_EPISODES=10
MAX_STEPS_PER_EPISODE=100
OPTIMIZED=true

# --- Configuração de Logging ---
LOG_LEVEL=INFO
LOG_FILE=output_hierarchical_uav/hierarchical_run.log

# --- Configuração das Células ---
# Células mmWave (gNBs secundárias): 2-8
CELL_LIST=2,3,4,5,6,7,8
NUM_GNBS=7

# --- Parâmetros de Mobilidade UAV (Shanghai Urban) ---
MIN_SPEED=2.0
MAX_SPEED=4.0
AREA_RADIUS=1500.0
CENTER_X=2000.0
CENTER_Y=2000.0

# --- Configuração do Banco de Dados ---
DB_TABLE_METRICS=hierarchical_metrics
DB_TABLE_EPISODES=episodes
DB_TABLE_ACTIONS=actions

# --- Limites de Latência (5G) ---
LATENCY_THRESHOLD_MS=50.0
LATENCY_PENALTY_WEIGHT=20.0

# --- Pesos da Recompensa ---
# ES (Energy Saving) weights
ES_THROUGHPUT_WEIGHT=0.31
ES_ENERGY_WEIGHT=0.19
ES_RLF_WEIGHT=0.2
ES_ON_COST_WEIGHT=0.1

# TS (Traffic Steering) weights
TS_HO_COST_FACTOR=10.0
TS_DECAY_FACTOR=0.1
TS_TIME_FACTOR=0.001
